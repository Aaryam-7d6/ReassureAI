{
	auto_https off
}

:80 {
        encode gzip zstd

        @backend_routes {
                path /api/v1 /api/v1/* /health /health/* /docs /docs/* /redoc /redoc/* /openapi.json
        }
        reverse_proxy @backend_routes backend:8000

        @n8n_routes {
                path /n8n /n8n/*
        }
        reverse_proxy @n8n_routes n8n:5678 {
                header_up X-Forwarded-Proto http
        }

        reverse_proxy frontend:5173
}

n8n.localhost {
        reverse_proxy n8n:5678 {
                header_up X-Forwarded-Proto http
        }
}
