# ─── MongoDB (Windows host → WSL2) ───────────────────────────────────────────
# Get your Windows IP: run this in WSL2 terminal:
# cat /etc/resolv.conf | grep nameserver | awk '{print $2}'
# If you enabled mirrored networking (Windows 11): use 127.0.0.1
MONGODB_URI=mongodb://127.0.0.1:27017/reassureai

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate a random secret — run this in terminal:
# python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
# i use 64 bytes (512 bits) for the secret, which is more than enough for HS256. You can use a shorter one if you want, but don't go below 32 bytes (256 bits) for security reasons.
# i generated it with following command : `openssl rand -hex 64`
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# ─── Ollama (Windows host → WSL2) ────────────────────────────────────────────
# Same IP as MongoDB above
OLLAMA_BASE_URL=http://127.0.0.1:11434

# ─── HuggingFace (leave empty for now — needed at TASK-009) ──────────────────
HUGGINGFACE_API_KEY=

# ─── Groq fallback (leave empty for now — needed at TASK-009) ────────────────
GROQ_API_KEY=

# ─── Qdrant Cloud (leave empty for now — needed at TASK-011) ─────────────────
QDRANT_URL=
QDRANT_API_KEY=

# ─── Local Upload Storage ───────────────────────────────────────────────────
UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE_BYTES=10485760

# ─── n8n Guardian Alert (leave empty for now — needed at TASK-005) ───────────
N8N_WEBHOOK_URL=http://localhost:8080/n8n/webhook

# ─── Frontend URL (for CORS whitelist) ───────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Backend URL (for CORS whitelist) ───────────────────────────────────────
BACKEND_URL=http://localhost:8000

# ─── Environment ─────────────────────────────────────────────────────────────
ENVIRONMENT=development

#--- n8n--
# use following for generating :
# openssl rand -hex 32   # use for N8N_ENCRYPTION_KEY
# openssl rand -hex 32   # use for N8N_JWT_SECRET

N8N_ENCRYPTION_KEY=
N8N_JWT_SECRET=



